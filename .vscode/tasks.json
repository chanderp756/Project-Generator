{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Agent: Backend Install",
      "type": "shell",
      "command": "pip install -r backend/requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Agent: Frontend Install",
      "type": "shell",
      "command": "cd frontend && npm install",
      "problemMatcher": []
    },
    {
      "label": "Agent: Backend Audit",
      "type": "shell",
      "command": "cd backend && ruff check . && black --check . && mypy .",
      "problemMatcher": []
    },
    {
      "label": "Agent: Frontend Audit",
      "type": "shell",
      "command": "cd frontend && npm install && npx tsc --noEmit && npm run lint",
      "problemMatcher": []
    },
    {
      "label": "Agent: Full Quality Gate",
      "type": "shell",
      "command": "python .agents/scripts/run_quality_gate.py --run",
      "problemMatcher": []
    }
  ]
}
