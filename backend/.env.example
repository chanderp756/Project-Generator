# ── LLM Provider Configuration ─────────────────────────────────────
# Set LLM_PROVIDER to one of: gemini, claude, openai
LLM_PROVIDER=groq

# Provide the API key for your selected provider
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Server Configuration ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
